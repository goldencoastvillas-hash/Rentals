generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RolUsuario {
  ADMIN
}

enum TipoServicio {
  CASA
  CARRO
}

enum EstadoReserva {
  PENDIENTE
  CONFIRMADA
  CANCELADA
}

enum OrigenBloqueo {
  INTERNA
  ICAL_AIRBNB
  ICAL_BOOKING
  ICAL_OTRO
}

model Cliente {
  id        Int       @id @default(autoincrement())
  nombre    String
  email     String
  telefono  String
  createdAt DateTime  @default(now())
  reservas  Reserva[]
}

model Usuario {
  id           Int        @id @default(autoincrement())
  nombre       String
  email        String     @unique
  passwordHash String
  rol          RolUsuario @default(ADMIN)
  createdAt    DateTime   @default(now())
}

model Servicio {
  id          Int          @id @default(autoincrement())
  tipo        TipoServicio
  nombre      String
  descripcion String       @db.Text
  precio      Decimal      @db.Decimal(12, 2)

  // Casa + mapa
  ubicacion        String?
  lat              Float?
  lng              Float?
  habitaciones     Int?
  banos            Int?
  aireAcondicionado Boolean?
  petFriendly       Boolean?
  piscina          Boolean?
  lavadora         Boolean?
  parking          Boolean?

  // Carro
  marca  String?
  modelo String?
  anio   Int?

  icalImportUrl String?

  reservas           Reserva[]
  bloqueosCalendario BloqueoCalendario[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tipo])
}

model Reserva {
  id           Int           @id @default(autoincrement())
  clienteId    Int
  servicioId   Int
  fechaInicio  DateTime      @db.Date
  fechaFin     DateTime      @db.Date
  estado       EstadoReserva @default(PENDIENTE)
  cliente      Cliente       @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  servicio     Servicio      @relation(fields: [servicioId], references: [id], onDelete: Cascade)
  historial    HistorialReserva[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([servicioId])
  @@index([clienteId])
}

model HistorialReserva {
  id            Int           @id @default(autoincrement())
  reservaId     Int
  estadoGuardado EstadoReserva
  createdAt     DateTime      @default(now())
  reserva       Reserva       @relation(fields: [reservaId], references: [id], onDelete: Cascade)

  @@index([reservaId, createdAt])
}

model BloqueoCalendario {
  id         Int           @id @default(autoincrement())
  servicioId Int
  inicio     DateTime      @db.Date
  fin        DateTime      @db.Date
  origen     OrigenBloqueo @default(ICAL_OTRO)
  servicio   Servicio      @relation(fields: [servicioId], references: [id], onDelete: Cascade)

  @@index([servicioId])
}
