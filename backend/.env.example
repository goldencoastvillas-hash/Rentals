# --- Supabase (proyecto Rentals) ---
# URL del proyecto (Settings → API)
SUPABASE_URL="https://yxhogojcagmloetoivgv.supabase.co"

# Claves (Settings → API Keys): anon para cliente; service_role solo en servidor
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Prisma: Settings → Database → Connection string → URI
# Sustituye [YOUR-PASSWORD] por la contraseña de la base (la definiste al crear el proyecto).
# Añade ?sslmode=require si Prisma lo requiere en tu entorno.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.yxhogojcagmloetoivgv.supabase.co:5432/postgres?sslmode=require"

JWT_SECRET="change-me-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"

ADMIN_EMAIL="admin@rentals.local"
ADMIN_PASSWORD="admin123"
ADMIN_NAME="Admin"

SUPPORT_EMAIL="soporte@rentals.local"
FRONTEND_URL="http://localhost:5173"
